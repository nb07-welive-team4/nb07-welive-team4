// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum JoinStatus {
  PENDING
  APPROVED
  REJECTED
  NEED_UPDATE
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  username          String   @unique
  contact           String   @unique
  password          String
  name              String
  avatar            String?
  role              Role     @default(USER)
  // 승인상태
  joinStatus        JoinStatus @default(PENDING)

  // 계정 활성화 여부
  isActive          Boolean  @default(true)

  // 유저 전용 필드
  apartmentName     String?  // 아파트 이름 (가입 시 입력)
  apartmentDong     String?  // 아파트 동 (가입 시 입력)
  apartmentHo       String?  // 아파트 호 (가입 시 입력)

  // 자신이 관리하는 아파트(Admin 전용)
  apartmentId       String?   @unique
  managedApartment  Apartment? @relation(fields: [apartmentId], references: [id])

  residentId    String?   @unique
  resident      Resident? @relation(fields: [residentId], references: [id], onDelete: Cascade)

  refreshTokens RefreshToken[]
  complaints Complaint[] @relation("UserComplaints")
  polls      Poll[]      @relation("UserPolls")
  notices    Notice[]    @relation("UserNotices")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ResidenceStatus {
  RESIDENCE
  NO_RESIDENCE
}

enum IsHouseholder {
  HOUSEHOLDER
  MEMBER
}

model Resident {
  id                String  @id @default(uuid())
  building          String
  unitNumber        String
  contact           String  @unique
  name              String
  residenceStatus   ResidenceStatus @default(RESIDENCE)
  isHouseholder     IsHouseholder @default(HOUSEHOLDER)
  isRegistered      Boolean @default(false)

  user              User?
  apartmentId       String
  apartment         Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, apartmentId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  device    String?
  ip        String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

enum ApartMentStatus {
  PENDING
  APPROVED
  REJECTED
}

model Apartment {
  id                  String   @id @default(uuid())
  name                String
  address             String
  officeNumber        String
  description         String
  startComplexNumber  String
  endComplexNumber    String
  startDongNumber     String
  endDongNumber       String
  startFloorNumber    String
  endFloorNumber      String
  startHoNumber       String
  endHoNumber         String
  apartmentStatus     ApartMentStatus @default(PENDING)

  // 관리자 관계 (1:1)
  admin        User?   @relation()

  residents      Resident[]

  // 아파트 게시판 관계
  boards             Board[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum BoardType {
  NOTICE
  POLL
  COMPLAINT
}

model Board {
  id          String  @id @default (uuid())
  name        String
  type        BoardType

  // 관계 설정
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id])

  complaints  Complaint[]
  polls       Poll[]
  notices     Notice[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Complaint {
  id          String     @id @default(uuid())
  title       String
  content     String
  isPublic    Boolean  @default(false)

  // 관계
  boardId     String
  board       Board    @relation(fields: [boardId], references: [id])

  authorId    String
  author      User     @relation("UserComplaints", fields: [authorId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum PollStatus {
  PENDING
  IN_PROGRESS
  CLOSED
}

model Poll {
  id                  String      @id @default(uuid())
  status              PollStatus  @default(PENDING)
  title               String
  content             String
  buildingPermission  Int         @default(0)
  startDate           DateTime // 투표 시작 날짜
  endDate             DateTime // 투표 종료 날짜

  // 관계 설정
  boardId             String
  board               Board       @relation(fields: [boardId], references: [id])
  authorId            String
  author              User        @relation("UserPolls", fields: [authorId], references: [id])

  options             PollOption[]

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model PollOption {
  id          String  @id @default(uuid())
  title       String // 옵션 제목 (예: 항목 1, 항목 2 등)

  // 관계 설정
  pollId      String
  poll        Poll    @relation(fields: [pollId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

enum NoticeCategory {
  MAINTENANCE
  EMERGENCY
  COMMUNITY
  RESIDENT_VOTE
  RESIDENT_COUNCIL
  ETC
}

model Notice {
  id          String   @id @default(uuid())
  category    NoticeCategory
  title       String
  content     String
  isPinned    Boolean  @default(false)
  startDate   DateTime?
  endDate     DateTime?

  // 관계 설정
  boardId     String
  board       Board    @relation(fields: [boardId], references: [id])
  authorId    String
  author      User     @relation("UserNotices", fields: [authorId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}