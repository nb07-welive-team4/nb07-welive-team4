// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum JoinStatus {
  PENDING
  APPROVED
  REJECTED
  NEED_UPDATE
}

model User {
  id                  String        @id @default(uuid())
  email               String        @unique
  username            String        @unique
  contact             String        @unique
  password            String
  name                String
  avatar              String?
  role                Role          @default(USER)
  joinStatus          JoinStatus    @default(PENDING)
  isActive            Boolean       @default(true)

  apartmentName       String?
  apartmentDong       String?
  apartmentHo         String?

  managedApartment    Apartment?    @relation("ApartmentAdmin")
  residenceApartment  Apartment?    @relation("ApartmentResidents", fields: [residentApartmentId], references: [id])
  residentApartmentId String?

  refreshTokens       RefreshToken[]
  complaints          Complaint[]   @relation("UserComplaints")
  polls               Poll[]        @relation("UserPolls")
  notices             Notice[]      @relation("UserNotices")
  votes               Vote[]        @relation("UserVotes")
  notifications       Notification[]

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  device    String?
  ip        String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

enum ApartMentStatus {
  PENDING
  APPROVED
  REJECTED
}

model Apartment {
  id                 String           @id @default(uuid())
  name               String
  address            String
  officeNumber       String
  description        String
  startComplexNumber String
  endComplexNumber   String
  startDongNumber    String
  endDongNumber      String
  startFloorNumber   String
  endFloorNumber     String
  startHoNumber      String
  endHoNumber        String
  apartmentStatus    ApartMentStatus  @default(PENDING)

  admin              User             @relation("ApartmentAdmin", fields: [adminId], references: [id])
  adminId            String           @unique

  residents          User[]           @relation("ApartmentResidents")
  boards             Board[]

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

enum BoardType {
  NOTICE
  POLL
  COMPLAINT
}

model Board {
  id          String      @id @default(uuid())
  name        String
  type        BoardType

  apartmentId String
  apartment   Apartment   @relation(fields: [apartmentId], references: [id])

  complaints  Complaint[]
  polls       Poll[]
  notices     Notice[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Complaint {
  id        String    @id @default(uuid())
  title     String
  content   String
  isPublic  Boolean   @default(false)

  boardId   String
  board     Board     @relation(fields: [boardId], references: [id])

  authorId  String
  author    User      @relation("UserComplaints", fields: [authorId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum PollStatus {
  PENDING
  IN_PROGRESS
  CLOSED
}

model Poll {
  id                 String       @id @default(uuid())
  status             PollStatus   @default(PENDING)
  title              String
  content            String
  buildingPermission Int          @default(0)
  startDate          DateTime
  endDate            DateTime

  boardId            String
  board              Board        @relation(fields: [boardId], references: [id])

  authorId           String
  author             User         @relation("UserPolls", fields: [authorId], references: [id])

  options            PollOption[]
  votes              Vote[]

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model PollOption {
  id        String     @id @default(uuid())
  title     String

  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     Vote[]

  createdAt DateTime   @default(now())
}

model Vote {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation("UserVotes", fields: [userId], references: [id], onDelete: Cascade)
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([userId, pollId])
}

enum NoticeCategory {
  MAINTENANCE
  EMERGENCY
  COMMUNITY
  RESIDENT_VOTE
  RESIDENT_COUNCIL
  ETC
}

enum NotificationType {
  COMPLAINT_RESOLVED
  NOTICE_CREATED
  POLL_CREATED
}

model Notification {
  notificationId   String           @id @default(uuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  content          String
  notificationType NotificationType
  isChecked        Boolean          @default(false)
  dedupeKey        String?          @unique
  complaintId      String?
  noticeId         String?
  pollId           String?
  notifiedAt       DateTime         @default(now())

  @@index([userId])
}

model Notice {
  id        String         @id @default(uuid())
  category  NoticeCategory
  title     String
  content   String
  isPinned  Boolean        @default(false)
  startDate DateTime?
  endDate   DateTime?

  boardId   String
  board     Board          @relation(fields: [boardId], references: [id])

  authorId  String
  author    User           @relation("UserNotices", fields: [authorId], references: [id])

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}