{
  "info": {
    "name": "WeLive - Polls API",
    "_postman_id": "welive-team4-polls",
    "description": "WeLive 투표 API 테스트 컬렉션",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "pollId",
      "value": "",
      "type": "string"
    },
    {
      "key": "optionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "boardId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "0. 사전 준비",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "description": "서버 상태 확인"
          }
        },
        {
          "name": "로그인",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"adminuser1\",\n  \"password\": \"password123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "로그인 성공 시 accessToken/refreshToken이 httpOnly 쿠키로 저장됩니다."
          }
        },
        {
          "name": "Poll 스케줄러 상태 확인",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/poll-scheduler/ping",
              "host": ["{{baseUrl}}"],
              "path": ["api", "poll-scheduler", "ping"]
            },
            "description": "서버에 스케줄러가 정상 동작 중인지 확인. 개발/운영용 엔드포인트."
          }
        }
      ]
    },
    {
      "name": "1. 투표 목록 조회",
      "item": [
        {
          "name": "전체 목록 (기본 페이징)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/polls?page=1&limit=11",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "11" }
              ]
            },
            "description": "인증 필요. 기본 limit은 11."
          }
        },
        {
          "name": "PENDING 상태 필터",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/polls?status=PENDING",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls"],
              "query": [{ "key": "status", "value": "PENDING" }]
            }
          }
        },
        {
          "name": "IN_PROGRESS 상태 필터",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/polls?status=IN_PROGRESS",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls"],
              "query": [{ "key": "status", "value": "IN_PROGRESS" }]
            }
          }
        },
        {
          "name": "CLOSED 상태 필터",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/polls?status=CLOSED",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls"],
              "query": [{ "key": "status", "value": "CLOSED" }]
            }
          }
        },
        {
          "name": "투표권자(buildingPermission) 필터",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/polls?buildingPermission=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls"],
              "query": [
                { "key": "buildingPermission", "value": "0", "description": "0=전체, 특정 동 번호 입력 가능" }
              ]
            }
          }
        },
        {
          "name": "keyword 검색",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/polls?keyword=동대표",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls"],
              "query": [{ "key": "keyword", "value": "동대표" }]
            },
            "description": "제목/내용 통합 검색."
          }
        },
        {
          "name": "인증 없이 요청 (401 확인)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/polls",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls"]
            },
            "description": "쿠키 없이 요청. 401 에러 확인."
          }
        }
      ]
    },
    {
      "name": "2. 투표 상세 조회",
      "item": [
        {
          "name": "상세 조회 - 정상",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/polls/{{pollId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls", "{{pollId}}"]
            },
            "description": "목록 조회 응답의 pollId를 컬렉션 변수 pollId에 입력 후 사용. boardName, options(id/title/voteCount) 포함 반환."
          }
        },
        {
          "name": "상세 조회 - 존재하지 않는 ID (404 확인)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/polls/nonexistent-id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls", "nonexistent-id"]
            }
          }
        }
      ]
    },
    {
      "name": "3. 투표 생성 (관리자)",
      "item": [
        {
          "name": "투표 생성 - 정상 (PENDING)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/polls",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"boardId\": \"{{boardId}}\",\n  \"title\": \"제 3기 동대표 선출\",\n  \"content\": \"동대표를 선출합니다. 투표에 참여해주세요.\",\n  \"buildingPermission\": 0,\n  \"startDate\": \"2025-06-01T00:00:00Z\",\n  \"endDate\": \"2025-06-10T00:00:00Z\",\n  \"options\": [\n    { \"title\": \"101호\" },\n    { \"title\": \"404호\" },\n    { \"title\": \"504호\" }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "boardId는 DB에서 POLL 타입 board의 id를 입력하세요. 생성 성공 시 201 반환."
          }
        },
        {
          "name": "투표 생성 - status 직접 지정 (IN_PROGRESS)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/polls",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"boardId\": \"{{boardId}}\",\n  \"status\": \"IN_PROGRESS\",\n  \"title\": \"즉시 시작 투표\",\n  \"content\": \"바로 시작되는 투표입니다.\",\n  \"buildingPermission\": 0,\n  \"startDate\": \"2025-06-01T00:00:00Z\",\n  \"endDate\": \"2025-06-10T00:00:00Z\",\n  \"options\": [\n    { \"title\": \"찬성\" },\n    { \"title\": \"반대\" }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "투표 생성 - 선택지 1개 (400 확인)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/polls",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"boardId\": \"{{boardId}}\",\n  \"title\": \"잘못된 투표\",\n  \"content\": \"선택지가 1개입니다.\",\n  \"buildingPermission\": 0,\n  \"startDate\": \"2025-06-01T00:00:00Z\",\n  \"endDate\": \"2025-06-10T00:00:00Z\",\n  \"options\": [\n    { \"title\": \"혼자\" }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "선택지 최소 2개 미충족 → 400 에러 확인."
          }
        },
        {
          "name": "투표 생성 - 날짜 오류 (400 확인)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/polls",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"boardId\": \"{{boardId}}\",\n  \"title\": \"날짜 오류 투표\",\n  \"content\": \"종료일이 시작일보다 이릅니다.\",\n  \"buildingPermission\": 0,\n  \"startDate\": \"2025-06-10T00:00:00Z\",\n  \"endDate\": \"2025-06-01T00:00:00Z\",\n  \"options\": [\n    { \"title\": \"A\" },\n    { \"title\": \"B\" }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "startDate >= endDate → 400 에러 확인."
          }
        }
      ]
    },
    {
      "name": "4. 투표 수정 (관리자, PENDING만)",
      "item": [
        {
          "name": "투표 수정 - 제목/내용 변경",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/polls/{{pollId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls", "{{pollId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"수정된 동대표 선출\",\n  \"content\": \"내용을 수정합니다.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "PENDING 상태 투표만 수정 가능."
          }
        },
        {
          "name": "투표 수정 - 선택지 교체",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/polls/{{pollId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls", "{{pollId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"options\": [\n    { \"title\": \"새 후보 A\" },\n    { \"title\": \"새 후보 B\" }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "기존 선택지 전체 삭제 후 새 선택지로 교체됩니다."
          }
        },
        {
          "name": "투표 수정 - IN_PROGRESS 상태 (400 확인)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/polls/{{pollId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls", "{{pollId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"수정 불가\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "IN_PROGRESS 상태의 pollId로 요청 → 400 에러 확인."
          }
        },
        {
          "name": "투표 수정 - 존재하지 않는 ID (404 확인)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/polls/nonexistent-id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls", "nonexistent-id"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"없는 투표\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "5. 투표 삭제 (관리자, PENDING만)",
      "item": [
        {
          "name": "투표 삭제 - 정상",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/polls/{{pollId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls", "{{pollId}}"]
            },
            "description": "PENDING 상태 투표만 삭제 가능."
          }
        },
        {
          "name": "투표 삭제 - IN_PROGRESS 상태 (400 확인)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/polls/{{pollId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls", "{{pollId}}"]
            },
            "description": "IN_PROGRESS 상태의 pollId로 요청 → 400 에러 확인."
          }
        },
        {
          "name": "투표 삭제 - 존재하지 않는 ID (404 확인)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/polls/nonexistent-id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "polls", "nonexistent-id"]
            }
          }
        }
      ]
    },
    {
      "name": "6. 투표 참여/취소",
      "item": [
        {
          "name": "투표하기 - 정상",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/options/{{optionId}}/vote",
              "host": ["{{baseUrl}}"],
              "path": ["api", "options", "{{optionId}}", "vote"]
            },
            "description": "상세 조회 응답의 options[].id를 컬렉션 변수 optionId에 입력 후 사용. IN_PROGRESS 상태 투표만 가능."
          }
        },
        {
          "name": "투표하기 - 중복 투표 (409 확인)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/options/{{optionId}}/vote",
              "host": ["{{baseUrl}}"],
              "path": ["api", "options", "{{optionId}}", "vote"]
            },
            "description": "같은 투표에 이미 참여한 경우 → 409 에러 확인."
          }
        },
        {
          "name": "투표하기 - PENDING 상태 투표 (400 확인)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/options/{{optionId}}/vote",
              "host": ["{{baseUrl}}"],
              "path": ["api", "options", "{{optionId}}", "vote"]
            },
            "description": "IN_PROGRESS가 아닌 투표의 optionId로 요청 → 400 에러 확인."
          }
        },
        {
          "name": "투표하기 - 존재하지 않는 optionId (404 확인)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/options/nonexistent-id/vote",
              "host": ["{{baseUrl}}"],
              "path": ["api", "options", "nonexistent-id", "vote"]
            }
          }
        },
        {
          "name": "투표 취소 - 정상",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/options/{{optionId}}/vote",
              "host": ["{{baseUrl}}"],
              "path": ["api", "options", "{{optionId}}", "vote"]
            },
            "description": "투표한 optionId로 요청. 취소 후 updatedOption 반환."
          }
        },
        {
          "name": "투표 취소 - 투표 내역 없음 (404 확인)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/options/{{optionId}}/vote",
              "host": ["{{baseUrl}}"],
              "path": ["api", "options", "{{optionId}}", "vote"]
            },
            "description": "투표하지 않은 상태에서 취소 요청 → 404 에러 확인."
          }
        }
      ]
    }
  ]
}
